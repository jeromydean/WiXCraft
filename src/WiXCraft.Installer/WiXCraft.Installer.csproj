<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <IsPackable>true</IsPackable>
    <PackageId>WiXCraft.Installer</PackageId>
    <Version>1.0.0</Version>
    <Authors>WiXCraft</Authors>
    <Description>MSBuild integration for WiX MSI projects (embedded UI and custom action wiring).</Description>
    <PackageTags>wix;msi;embedded-ui;installer</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <None Include="build\**" Pack="true" PackagePath="build\" />
  </ItemGroup>

  <!-- Packaging-only project: satisfy solution Build without compiling an assembly. -->
  <Target Name="Build" />
  <Target Name="Rebuild" DependsOnTargets="Clean;Build" />

</Project>
