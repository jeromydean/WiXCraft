<Project>
  <PropertyGroup Condition="'$(UseWiXCraftInstaller)' == 'true'">
    <WiXCraftInstallerContentRoot Condition="'$(WiXCraftInstallerContentRoot)' == ''">$(MSBuildThisFileDirectory)content</WiXCraftInstallerContentRoot>
  </PropertyGroup>

  <Target Name="WiXCraftInstallerResolveCancellationProject"
          BeforeTargets="WiXCraftInstallerGenerateInclude"
          Condition="'$(UseWiXCraftInstaller)' == 'true'">
    <MSBuild Projects="@(ProjectReference)"
             Targets="GetWiXCraftCancellationMetadata"
             Condition="'$(WiXCraftCancellationProjectName)' == ''"
             BuildInParallel="true"
             SkipNonexistentTargets="true">
      <Output TaskParameter="TargetOutputs" ItemName="_WiXCraftCancellationMetadata" />
    </MSBuild>

    <PropertyGroup Condition="'$(WiXCraftCancellationProjectName)' == '' and '@(_WiXCraftCancellationMetadata-&gt;Count())' != '0'">
      <WiXCraftCancellationProjectName>@(_WiXCraftCancellationMetadata->'%(Identity)')</WiXCraftCancellationProjectName>
    </PropertyGroup>
  </Target>

  <Target Name="WiXCraftInstallerResolveEmbeddedUiProject"
          BeforeTargets="WiXCraftInstallerGenerateInclude"
          Condition="'$(UseWiXCraftInstaller)' == 'true'">
    <MSBuild Projects="@(ProjectReference)"
             Targets="GetWiXCraftEmbeddedUiMetadata"
             Condition="'$(WiXCraftEmbeddedUiProjectName)' == ''"
             BuildInParallel="true"
             SkipNonexistentTargets="true">
      <Output TaskParameter="TargetOutputs" ItemName="_WiXCraftEmbeddedUiMetadata" />
    </MSBuild>

    <PropertyGroup Condition="'$(WiXCraftEmbeddedUiProjectName)' == '' and '@(_WiXCraftEmbeddedUiMetadata-&gt;Count())' != '0'">
      <WiXCraftEmbeddedUiProjectName>@(_WiXCraftEmbeddedUiMetadata->'%(Identity)')</WiXCraftEmbeddedUiProjectName>
    </PropertyGroup>

    <Error Condition="'$(WiXCraftIncludeEmbeddedUi)' == 'true' and '$(WiXCraftEmbeddedUiProjectName)' == ''"
           Text="UseWiXCraftInstaller with WiXCraftIncludeEmbeddedUi=true requires WiXCraftEmbeddedUiProjectName or a ProjectReference to a project with UseWiXCraftEmbeddedUi=true." />
  </Target>

  <Target Name="WiXCraftInstallerGenerateInclude"
          BeforeTargets="PreBuildEvent"
          Condition="'$(UseWiXCraftInstaller)' == 'true'">
    <PropertyGroup>
      <WiXCraftInstallerContentRoot Condition="'$(WiXCraftInstallerContentRoot)' == ''">$(MSBuildThisFileDirectory)content</WiXCraftInstallerContentRoot>
      <WiXCraftGeneratedIncludePath Condition="'$(WiXCraftGeneratedIncludePath)' == ''">$(MSBuildProjectDirectory)\WiXCraft.generated.wxi</WiXCraftGeneratedIncludePath>
      <WiXCraftCancellationProjectName Condition="'$(WiXCraftCancellationProjectName)' == ''">WiXCraft.CustomActions</WiXCraftCancellationProjectName>
      <WiXCraftUseCancellationActions Condition="'$(WiXCraftUseCancellationActions)' == ''">true</WiXCraftUseCancellationActions>
      <WiXCraftIncludeEmbeddedUi Condition="'$(WiXCraftIncludeEmbeddedUi)' == ''">true</WiXCraftIncludeEmbeddedUi>
      <_GenerateEmbeddedUiWxiScript>$(WiXCraftInstallerContentRoot)\GenerateEmbeddedUiWxi.ps1</_GenerateEmbeddedUiWxiScript>
      <_IncludeCancellationActions Condition="'$(WiXCraftUseCancellationActions)' == 'true'">-IncludeCancellationActions</_IncludeCancellationActions>
      <_IncludeEmbeddedUi Condition="'$(WiXCraftIncludeEmbeddedUi)' == 'true'">-IncludeEmbeddedUi</_IncludeEmbeddedUi>
      <WiXCraftSequenceHooksManifestPath Condition="'$(WiXCraftSequenceHooksManifestPath)' == ''">$(MSBuildProjectDirectory)\obj\WiXCraft.sequencehooks.txt</WiXCraftSequenceHooksManifestPath>
    </PropertyGroup>

    <MakeDir Directories="$([System.IO.Path]::GetDirectoryName('$(WiXCraftSequenceHooksManifestPath)'))" Condition="'@(WiXCraftSequenceHook)' != ''" />

    <WriteLinesToFile
      File="$(WiXCraftSequenceHooksManifestPath)"
      Lines="@(WiXCraftSequenceHook->'%(Identity)|%(Before)|%(After)|%(Condition)|%(Payload)|%(Buttons)')"
      Overwrite="true"
      Condition="'@(WiXCraftSequenceHook)' != ''" />

    <WriteLinesToFile
      File="$(WiXCraftSequenceHooksManifestPath)"
      Lines=""
      Overwrite="true"
      Condition="'@(WiXCraftSequenceHook)' == ''" />

    <PropertyGroup>
      <_SequenceHooksFileArg Condition="Exists('$(WiXCraftSequenceHooksManifestPath)')">-SequenceHooksFile "$(WiXCraftSequenceHooksManifestPath)"</_SequenceHooksFileArg>
    </PropertyGroup>

    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(_GenerateEmbeddedUiWxiScript)&quot; -UiProjectName &quot;$(WiXCraftEmbeddedUiProjectName)&quot; -CancellationProjectName &quot;$(WiXCraftCancellationProjectName)&quot; -OutputPath &quot;$(WiXCraftGeneratedIncludePath)&quot; $(_IncludeCancellationActions) $(_IncludeEmbeddedUi) $(_SequenceHooksFileArg)" />

    <Message Importance="high"
             Text="WiXCraft.Installer generated $(WiXCraftGeneratedIncludePath) for embedded UI project '$(WiXCraftEmbeddedUiProjectName)'." />
  </Target>

  <Target Name="GetWiXCraftCancellationMetadata" Returns="@(WiXCraftCancellationMetadata)">
    <ItemGroup>
      <WiXCraftCancellationMetadata Include="$(MSBuildProjectName)"
                                  Condition="'$(UseWiXCraftCancellationActions)' == 'true'" />
    </ItemGroup>
  </Target>

  <Target Name="GetWiXCraftEmbeddedUiMetadata" Returns="@(WiXCraftEmbeddedUiMetadata)">
    <ItemGroup>
      <WiXCraftEmbeddedUiMetadata Include="$(MSBuildProjectName)"
                                  Condition="'$(UseWiXCraftEmbeddedUi)' == 'true'" />
    </ItemGroup>
  </Target>
</Project>
