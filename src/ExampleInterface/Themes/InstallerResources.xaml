<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <SolidColorBrush x:Key="Installer.HeaderBackgroundBrush" Color="#FF5C1212" />
  <SolidColorBrush x:Key="Installer.HeaderForegroundBrush" Color="White" />
  <SolidColorBrush x:Key="Installer.SubtleForegroundBrush" Color="#CCFFFFFF" />
  <SolidColorBrush x:Key="Installer.CardBackgroundBrush" Color="#FF211818" />
  <SolidColorBrush x:Key="Installer.CardBorderBrush" Color="#FF4A3030" />
  <SolidColorBrush x:Key="Installer.FooterBackgroundBrush" Color="#FF140A0A" />
  <SolidColorBrush x:Key="Installer.MutedTextBrush" Color="#FF94A3B8" />
  <SolidColorBrush x:Key="Installer.SectionForegroundBrush" Color="#FFF1F5F9" />
  <SolidColorBrush x:Key="Installer.PanelBackgroundBrush" Color="#FF1A1212" />

  <Style x:Key="Installer.CardBorder" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource Installer.CardBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource Installer.CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="16" />
  </Style>

  <Style x:Key="Installer.SectionTitle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="15" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource Installer.SectionForegroundBrush}" />
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>

  <Style x:Key="Installer.BodyText" TargetType="TextBlock">
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Foreground" Value="{StaticResource Installer.MutedTextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="LineHeight" Value="20" />
  </Style>

  <Style x:Key="Installer.PrimaryButton" TargetType="Button">
    <Setter Property="Height" Value="36" />
    <Setter Property="MinWidth" Value="110" />
    <Setter Property="Padding" Value="16,0" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Background" Value="{DynamicResource AccentColorBrush}" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style x:Key="Installer.SecondaryButton" TargetType="Button">
    <Setter Property="Height" Value="36" />
    <Setter Property="MinWidth" Value="96" />
    <Setter Property="Padding" Value="14,0" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource Installer.CardBorderBrush}" />
    <Setter Property="Background" Value="{StaticResource Installer.CardBackgroundBrush}" />
    <Setter Property="Foreground" Value="{StaticResource Installer.SectionForegroundBrush}" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>

  <Style x:Key="Installer.FeatureCard" TargetType="Border" BasedOn="{StaticResource Installer.CardBorder}">
    <Setter Property="Margin" Value="0,0,0,8" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="Background" Value="{StaticResource Installer.PanelBackgroundBrush}" />
  </Style>

</ResourceDictionary>
