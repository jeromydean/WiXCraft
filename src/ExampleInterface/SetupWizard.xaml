<Window x:Class="ExampleInterface.SetupWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Example Setup" Height="560" Width="720"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock x:Name="headerTextBlock" Grid.Row="0" FontSize="20" FontWeight="SemiBold"
               Margin="0,0,0,8" TextWrapping="Wrap" />

    <TextBlock x:Name="descriptionTextBlock" Grid.Row="1" Margin="0,0,0,12"
               TextWrapping="Wrap" Opacity="0.85" />

    <TabControl Grid.Row="2" Margin="0,0,0,12">
      <TabItem Header="Features">
        <StackPanel Margin="8">
          <TextBlock Text="Select the features you want installed." Margin="0,0,0,8" />
          <StackPanel x:Name="featurePanel" />
        </StackPanel>
      </TabItem>
      <TabItem Header="Session properties">
        <DataGrid x:Name="sessionPropertiesGrid" IsReadOnly="True" AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" SelectionMode="Extended">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Property" Binding="{Binding Name}" Width="200" />
            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>
      <TabItem Header="Messages">
        <TextBox x:Name="messagesTextBox" IsReadOnly="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" />
      </TabItem>
    </TabControl>

    <StackPanel x:Name="freshInstallActionsPanel" Grid.Row="3" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,0,0,8">
      <Button x:Name="installButton" Content="Install" Width="110" Margin="0,0,8,0" Click="installButton_Click" />
    </StackPanel>

    <StackPanel x:Name="maintenanceActionsPanel" Grid.Row="3" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,0,0,8" Visibility="Collapsed">
      <Button x:Name="repairButton" Content="Repair" Width="110" Margin="0,0,8,0" Click="repairButton_Click" />
      <Button x:Name="modifyButton" Content="Modify" Width="110" Margin="0,0,8,0" Click="modifyButton_Click" />
      <Button x:Name="removeButton" Content="Remove" Width="110" Margin="0,0,8,0" Click="removeButton_Click" />
    </StackPanel>

    <StackPanel x:Name="modifyActionsPanel" Grid.Row="3" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,0,0,8" Visibility="Collapsed">
      <Button x:Name="backButton" Content="Back" Width="90" Margin="0,0,8,0" Click="backButton_Click" />
      <Button x:Name="applyModifyButton" Content="Apply changes" Width="120" Margin="0,0,8,0" Click="applyModifyButton_Click" />
    </StackPanel>

    <StackPanel x:Name="uninstallConfirmPanel" Grid.Row="3" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,0,0,8" Visibility="Collapsed">
      <Button x:Name="confirmRemoveButton" Content="Remove" Width="110" Margin="0,0,8,0" Click="removeButton_Click" />
    </StackPanel>

    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
      <Button x:Name="exitButton" Content="Exit" Width="90" Visibility="Collapsed" Click="exitButton_Click" />
      <Button x:Name="cancelButton" Content="Cancel" Width="90" Click="cancelButton_Click" />
    </StackPanel>

    <StackPanel Grid.Row="5">
      <ProgressBar x:Name="progressBar" Height="18" Minimum="0" Maximum="100" Visibility="Collapsed" />
      <Label x:Name="progressLabel" Content="0%" HorizontalAlignment="Center" Visibility="Collapsed" />
    </StackPanel>
  </Grid>
</Window>
