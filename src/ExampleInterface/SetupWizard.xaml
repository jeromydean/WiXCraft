<Window x:Class="ExampleInterface.SetupWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Example Setup" Height="520" Width="720"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="ExampleSetup" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />

    <TabControl Grid.Row="1" Margin="0,0,0,12">
      <TabItem Header="Session properties">
        <DataGrid x:Name="sessionPropertiesGrid" IsReadOnly="True" AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" SelectionMode="Extended">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Property" Binding="{Binding Name}" Width="200" />
            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>
      <TabItem Header="Messages">
        <TextBox x:Name="messagesTextBox" IsReadOnly="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" />
      </TabItem>
    </TabControl>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
      <Button x:Name="installButton" Content="Install" Width="90" Margin="0,0,8,0" Click="installButton_Click" />
      <Button x:Name="repairButton" Content="Repair" Width="90" Margin="0,0,8,0" Visibility="Collapsed" Click="repairButton_Click" />
      <Button x:Name="uninstallButton" Content="Uninstall" Width="90" Margin="0,0,8,0" Visibility="Collapsed" Click="uninstallButton_Click" />
      <Button x:Name="exitButton" Content="Exit" Width="90" Visibility="Collapsed" Click="exitButton_Click" />
      <Button x:Name="cancelButton" Content="Cancel" Width="90" Click="cancelButton_Click" />
    </StackPanel>

    <StackPanel Grid.Row="3">
      <ProgressBar x:Name="progressBar" Height="18" Minimum="0" Maximum="100" Visibility="Collapsed" />
      <Label x:Name="progressLabel" Content="0%" HorizontalAlignment="Center" Visibility="Collapsed" />
    </StackPanel>
  </Grid>
</Window>
