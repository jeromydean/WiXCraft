<Window x:Class="ExampleInterface.Views.SetupWizardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Example Setup" Height="560" Width="720"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
  </Window.Resources>
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" FontSize="20" FontWeight="SemiBold"
               Margin="0,0,0,8" TextWrapping="Wrap" Text="{Binding HeaderText}" />

    <TextBlock Grid.Row="1" Margin="0,0,0,12"
               TextWrapping="Wrap" Opacity="0.85" Text="{Binding DescriptionText}" />

    <TabControl Grid.Row="2" Margin="0,0,0,12">
      <TabItem Header="Features">
        <StackPanel Margin="8">
          <TextBlock Text="Select the features you want installed." Margin="0,0,0,8" />
          <ItemsControl ItemsSource="{Binding Features}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <CheckBox Content="{Binding DisplayName}"
                          IsChecked="{Binding IsSelected}"
                          IsEnabled="{Binding IsEnabled}"
                          Margin="0,0,0,6" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </TabItem>
      <TabItem Header="Session properties">
        <DataGrid ItemsSource="{Binding SessionProperties}" IsReadOnly="True" AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" SelectionMode="Extended">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Property" Binding="{Binding Name}" Width="200" />
            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>
      <TabItem Header="Messages">
        <TextBox Text="{Binding MessagesText, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" />
      </TabItem>
    </TabControl>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8"
                Visibility="{Binding ShowFreshInstallActions, Converter={StaticResource BoolToVisibility}}">
      <Button Content="Install" Width="110" Margin="0,0,8,0" Command="{Binding InstallCommand}" />
    </StackPanel>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8"
                Visibility="{Binding ShowMaintenanceActions, Converter={StaticResource BoolToVisibility}}">
      <Button Content="Repair" Width="110" Margin="0,0,8,0" Command="{Binding RepairCommand}" />
      <Button Content="Modify" Width="110" Margin="0,0,8,0" Command="{Binding EnterModifyCommand}" />
      <Button Content="Remove" Width="110" Margin="0,0,8,0" Command="{Binding RemoveCommand}" />
    </StackPanel>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8"
                Visibility="{Binding ShowModifyActions, Converter={StaticResource BoolToVisibility}}">
      <Button Content="Back" Width="90" Margin="0,0,8,0" Command="{Binding BackCommand}" />
      <Button Content="Apply changes" Width="120" Margin="0,0,8,0" Command="{Binding ApplyModifyCommand}" />
    </StackPanel>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8"
                Visibility="{Binding ShowUninstallConfirm, Converter={StaticResource BoolToVisibility}}">
      <Button Content="Remove" Width="110" Margin="0,0,8,0" Command="{Binding RemoveCommand}" />
    </StackPanel>

    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
      <Button Content="Exit" Width="90" Margin="0,0,8,0"
              Visibility="{Binding ShowExitButton, Converter={StaticResource BoolToVisibility}}"
              Command="{Binding ExitCommand}" />
      <Button Content="Cancel" Width="90"
              Visibility="{Binding ShowCancelButton, Converter={StaticResource BoolToVisibility}}"
              IsEnabled="{Binding IsCancelEnabled}"
              Command="{Binding CancelCommand}" />
    </StackPanel>

    <StackPanel Grid.Row="5"
                Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVisibility}}">
      <ProgressBar Height="18" Minimum="0" Maximum="100" Value="{Binding ProgressValue}" />
      <Label Content="{Binding ProgressText}" HorizontalAlignment="Center" />
    </StackPanel>
  </Grid>
</Window>
