<UserControl x:Class="ExampleInterface.Views.DatabaseConnectionPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/ExampleInterface;component/Themes/InstallerResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>
  <StackPanel>
    <Border Style="{StaticResource Installer.CardBorder}">
      <StackPanel>
        <TextBlock Text="Connect to Server" Style="{StaticResource Installer.SectionTitle}" />
        <TextBlock Text="Configure the SQL Server connection used by the application after installation."
                   Style="{StaticResource Installer.BodyText}" Margin="0,0,0,16" />

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="Server type:"
                     VerticalAlignment="Center" Margin="0,0,12,12"
                     Foreground="{StaticResource Installer.SectionForegroundBrush}" />
          <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12"
                    IsEnabled="False" SelectedIndex="0">
            <ComboBoxItem Content="Database Engine" />
          </ComboBox>

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Server name:"
                     VerticalAlignment="Center" Margin="0,0,12,12"
                     Foreground="{StaticResource Installer.SectionForegroundBrush}" />
          <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,8,12"
                   Text="{Binding ServerName, UpdateSourceTrigger=PropertyChanged}" />
          <Button Grid.Row="1" Grid.Column="2" Content="Browse..."
                  Style="{StaticResource Installer.SecondaryButton}" Margin="0,0,0,12"
                  Command="{Binding BrowseServersCommand}" />

          <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Text="Authentication"
                     FontWeight="SemiBold" Margin="0,4,0,8"
                     Foreground="{StaticResource Installer.SectionForegroundBrush}" />

          <RadioButton Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8"
                       Content="Windows Authentication"
                       IsChecked="{Binding UseWindowsAuthentication}" />
          <RadioButton Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12"
                       Content="SQL Server Authentication"
                       IsChecked="{Binding UseSqlAuthentication}" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Login:"
                     VerticalAlignment="Center" Margin="0,0,12,12"
                     Foreground="{StaticResource Installer.SectionForegroundBrush}" />
          <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12"
                   Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                   IsEnabled="{Binding IsSqlAuthentication}" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="Password:"
                     VerticalAlignment="Center" Margin="0,0,12,12"
                     Foreground="{StaticResource Installer.SectionForegroundBrush}" />
          <PasswordBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12"
                       IsEnabled="{Binding IsSqlAuthentication}" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="Database:"
                     VerticalAlignment="Center" Margin="0,0,12,0"
                     Foreground="{StaticResource Installer.SectionForegroundBrush}" />
          <ComboBox Grid.Row="7" Grid.Column="1" Margin="0,0,8,0"
                    ItemsSource="{Binding Databases}"
                    SelectedItem="{Binding SelectedDatabase}" />
          <Button Grid.Row="7" Grid.Column="2" Content="Refresh"
                  Style="{StaticResource Installer.SecondaryButton}"
                  Command="{Binding RefreshDatabasesCommand}" />
        </Grid>

        <StackPanel Margin="0,16,0,0">
          <CheckBox Content="Encrypt connection" Margin="0,0,0,8"
                    IsChecked="{Binding EncryptConnection}" />
          <CheckBox Content="Trust server certificate" Margin="0,0,0,16"
                    IsChecked="{Binding TrustServerCertificate}" />
        </StackPanel>

        <StackPanel Orientation="Horizontal">
          <Button Style="{StaticResource Installer.PrimaryButton}"
                  Command="{Binding TestConnectionCommand}">
            <StackPanel Orientation="Horizontal">
              <iconPacks:PackIconMaterial Kind="Connection" Width="16" Height="16"
                                          VerticalAlignment="Center" Margin="0,0,8,0" />
              <TextBlock Text="Test Connection" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>

        <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Installer.BodyText}"
                   Margin="0,12,0,0" TextWrapping="Wrap" />
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
