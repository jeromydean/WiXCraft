<UserControl x:Class="ExampleInterface.Views.WebsiteConfigurationPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/ExampleInterface;component/Themes/InstallerResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>
  <StackPanel>
    <Border Style="{StaticResource Installer.CardBorder}" Margin="0,0,0,16">
      <StackPanel>
        <TextBlock Text="Site" Style="{StaticResource Installer.SectionTitle}" />
        <Grid Margin="0,0,0,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="Site name:"
                     VerticalAlignment="Center" Margin="0,0,12,12"
                     Foreground="{StaticResource Installer.SectionForegroundBrush}" />
          <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12"
                   Text="{Binding SiteName, UpdateSourceTrigger=PropertyChanged}" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Physical path:"
                     VerticalAlignment="Center" Margin="0,0,12,0"
                     Foreground="{StaticResource Installer.SectionForegroundBrush}" />
          <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,8,0"
                   Text="{Binding PhysicalPath, UpdateSourceTrigger=PropertyChanged}" />
          <Button Grid.Row="1" Grid.Column="2" Content="Browse..."
                  Style="{StaticResource Installer.SecondaryButton}"
                  Command="{Binding BrowsePhysicalPathCommand}" />
        </Grid>
      </StackPanel>
    </Border>

    <Border Style="{StaticResource Installer.CardBorder}" Margin="0,0,0,16">
      <StackPanel>
        <TextBlock Text="Bindings" Style="{StaticResource Installer.SectionTitle}" />
        <TextBlock Text="HTTP/HTTPS endpoint and host header for the site."
                   Style="{StaticResource Installer.BodyText}" Margin="0,0,0,12" />
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="IP address:"
                     VerticalAlignment="Center" Margin="0,0,12,12"
                     Foreground="{StaticResource Installer.SectionForegroundBrush}" />
          <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,12"
                    ItemsSource="{Binding IpAddresses}"
                    SelectedItem="{Binding SelectedIpAddress}" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Port:"
                     VerticalAlignment="Center" Margin="0,0,12,12"
                     Foreground="{StaticResource Installer.SectionForegroundBrush}" />
          <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,12"
                   Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Host name:"
                     VerticalAlignment="Center" Margin="0,0,12,12"
                     Foreground="{StaticResource Installer.SectionForegroundBrush}" />
          <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,12"
                   Text="{Binding HostHeader, UpdateSourceTrigger=PropertyChanged}" />

          <StackPanel Grid.Row="3" Grid.Column="1">
            <CheckBox Content="Enable HTTPS (SSL)" Margin="0,0,0,8"
                      IsChecked="{Binding EnableHttps}" />
            <CheckBox Content="Require SSL" Margin="0,0,0,8"
                      IsChecked="{Binding RequireHttps}"
                      IsEnabled="{Binding EnableHttps}" />
            <CheckBox Content="Redirect HTTP to HTTPS"
                      IsChecked="{Binding RedirectHttpToHttps}"
                      IsEnabled="{Binding EnableHttps}" />
          </StackPanel>
        </Grid>

        <Grid Margin="0,12,0,0"
              IsEnabled="{Binding EnableHttps}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="SSL certificate:"
                     VerticalAlignment="Center" Margin="0,0,12,0"
                     Foreground="{StaticResource Installer.SectionForegroundBrush}" />
          <ComboBox Grid.Column="1"
                    ItemsSource="{Binding SslCertificates}"
                    SelectedItem="{Binding SelectedSslCertificate}" />
        </Grid>
      </StackPanel>
    </Border>

    <Border Style="{StaticResource Installer.CardBorder}" Margin="0,0,0,16">
      <StackPanel>
        <TextBlock Text="Security" Style="{StaticResource Installer.SectionTitle}" />
        <TextBlock Text="Authentication settings applied to the site in IIS."
                   Style="{StaticResource Installer.BodyText}" Margin="0,0,0,12" />
        <CheckBox Content="Enable anonymous authentication" Margin="0,0,0,8"
                  IsChecked="{Binding EnableAnonymousAuthentication}" />
        <CheckBox Content="Enable Windows authentication"
                  IsChecked="{Binding EnableWindowsAuthentication}" />
      </StackPanel>
    </Border>

    <Border Style="{StaticResource Installer.CardBorder}">
      <StackPanel>
        <TextBlock Text="Application Pool" Style="{StaticResource Installer.SectionTitle}" />
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="Pool name:"
                     VerticalAlignment="Center" Margin="0,0,12,12"
                     Foreground="{StaticResource Installer.SectionForegroundBrush}" />
          <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,12"
                   Text="{Binding ApplicationPoolName, UpdateSourceTrigger=PropertyChanged}" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text=".NET CLR:"
                     VerticalAlignment="Center" Margin="0,0,12,12"
                     Foreground="{StaticResource Installer.SectionForegroundBrush}" />
          <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,12"
                    ItemsSource="{Binding ClrVersions}"
                    SelectedItem="{Binding SelectedClrVersion}" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Pipeline:"
                     VerticalAlignment="Center" Margin="0,0,12,0"
                     Foreground="{StaticResource Installer.SectionForegroundBrush}" />
          <ComboBox Grid.Row="2" Grid.Column="1"
                    ItemsSource="{Binding PipelineModes}"
                    SelectedItem="{Binding SelectedPipelineMode}" />
        </Grid>

        <Button Style="{StaticResource Installer.PrimaryButton}"
                Command="{Binding TestBindingCommand}">
          <StackPanel Orientation="Horizontal">
            <iconPacks:PackIconMaterial Kind="WebCheck" Width="16" Height="16"
                                        VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBlock Text="Test binding" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Installer.BodyText}"
                   Margin="0,12,0,0" TextWrapping="Wrap" />
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
