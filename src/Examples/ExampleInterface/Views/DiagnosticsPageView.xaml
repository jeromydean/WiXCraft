<UserControl x:Class="ExampleInterface.Views.DiagnosticsPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/ExampleInterface;component/Themes/InstallerResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>
  <StackPanel>
    <TextBlock Text="Diagnostics" Style="{StaticResource Installer.SectionTitle}" />
    <TextBlock Text="Session properties, MSI execute sequence actions, and installer messages for troubleshooting."
               Style="{StaticResource Installer.BodyText}" Margin="0,0,0,12" />
    <mah:MetroTabControl mah:TabControlHelper.UnderlineBrush="{DynamicResource AccentColorBrush}">
      <TabItem Header="Session">
        <DataGrid ItemsSource="{Binding SessionProperties}" IsReadOnly="True" AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" SelectionMode="Extended" Margin="0,8,0,0"
                  BorderThickness="0" Background="Transparent">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Property" Binding="{Binding Name}" Width="200" />
            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>
      <TabItem Header="Execute sequence">
        <Grid Margin="0,8,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0"
                     Text="MSI execute sequence actions reported through ProcessMessage (no custom actions required)."
                     Style="{StaticResource Installer.BodyText}" Margin="0,0,0,8" />
          <ListView Grid.Row="1"
                    ItemsSource="{Binding ExecuteSequenceTimeline}"
                    BorderBrush="{StaticResource Installer.CardBorderBrush}"
                    Background="{StaticResource Installer.PanelBackgroundBrush}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,2">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92" />
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0"
                             Text="{Binding TimestampText}"
                             FontFamily="Consolas"
                             FontSize="12"
                             Foreground="{StaticResource Installer.MutedTextBrush}"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding KindLabel}"
                             FontSize="12"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource AccentColorBrush}"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="2"
                             Text="{Binding DisplayText}"
                             FontSize="12"
                             TextWrapping="Wrap"
                             Foreground="{StaticResource Installer.SectionForegroundBrush}"
                             VerticalAlignment="Center" />
                </Grid>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </Grid>
      </TabItem>
      <TabItem Header="Sequence hooks">
        <Grid Margin="0,8,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0"
                     Text="Interactive hooks raised by WiXCraft SequenceHook custom actions during the execute sequence."
                     Style="{StaticResource Installer.BodyText}" Margin="0,0,0,8" />
          <ListView Grid.Row="1"
                    ItemsSource="{Binding SequenceHookTimeline}"
                    BorderBrush="{StaticResource Installer.CardBorderBrush}"
                    Background="{StaticResource Installer.PanelBackgroundBrush}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,2">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92" />
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0"
                             Text="{Binding TimestampText}"
                             FontFamily="Consolas"
                             FontSize="12"
                             Foreground="{StaticResource Installer.MutedTextBrush}"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1"
                             Text="Hook"
                             FontSize="12"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource AccentColorBrush}"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="2"
                             Text="{Binding DisplayText}"
                             FontSize="12"
                             TextWrapping="Wrap"
                             Foreground="{StaticResource Installer.SectionForegroundBrush}"
                             VerticalAlignment="Center" />
                </Grid>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </Grid>
      </TabItem>
      <TabItem Header="Log">
        <TextBox Text="{Binding MessagesText, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" Margin="0,8,0,0"
                 FontFamily="Consolas" FontSize="12"
                 Background="{StaticResource Installer.PanelBackgroundBrush}"
                 Foreground="{StaticResource Installer.SectionForegroundBrush}"
                 BorderBrush="{StaticResource Installer.CardBorderBrush}" />
      </TabItem>
    </mah:MetroTabControl>
  </StackPanel>
</UserControl>
